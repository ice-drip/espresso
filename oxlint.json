{
  "rules": {
    "no-unused-vars": "error",
    "no-explicit-any": "warn",
    "no-console": "warn",
    "no-debugger": "error",
    "no-duplicate-case": "error",
    "no-empty": "error",
    "no-extra-semi": "error",
    "no-unreachable": "error",
    "curly": "error",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error",
    "prefer-template": "warn",
    "no-param-reassign": "warn",
    "no-shadow": "warn",
    "typescript/no-unused-vars": "error",
    "typescript/no-explicit-any": "warn"
  },
  "extends": [
    "typescript",
    "recommended"
  ],
  "plugins": [
    "typescript"
  ],
  "parser": "typescript",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "project": "./tsconfig.json"
  }
}
