{
  "name": "@ice-drip/espresso",
  "version": "2.0.0",
  "description": "TypeScript crypto library with Web Crypto + pure JS dual runtime",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/typings/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/typings/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@rslib/core": "^0.x",
    "typescript": "^5.5",
    "vitest": "^2.x",
    "crypto-js": "^4.2.0",
    "@types/crypto-js": "^4.2.0"
  },
  "keywords": ["crypto", "aes", "des", "sha", "hmac", "web-crypto"],
  "license": "GPL-3.0"
}
