{
  "name": "@kaffee/espresso-monorepo",
  "private": true,
  "description": "TypeScript crypto library with Web Crypto + pure JS dual runtime",
  "scripts": {
    "build": "cd packages/espresso && pnpm build",
    "test": "cd packages/test && pnpm test",
    "lint": "cd packages/espresso && pnpm lint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint:oxlint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.5"
  },
  "license": "GPL-3.0"
}
